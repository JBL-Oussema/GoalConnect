# URL de connexion à la base de données (MySQL par défaut)
# Format : mysql://user:password@localhost:3306/dbname
DATABASE_URL="mysql://username:password@localhost:3306/goalconnect_db"

# Clé secrète pour le chiffrement des sessions (NextAuth)
# On peut utiliser n'importe quelle chaîne de caractères longue et aléatoire
AUTH_SECRET="votre_cle_secrete_ici"

# URL de base de l'application en développement
NEXTAUTH_URL="http://localhost:3000"

# Nom public de l'application
NEXT_PUBLIC_APP_NAME="GoalConnect"
